# Python virtual environments
.venv/
venv/
ENV/
env/

# Python cache & compiled files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Local Environment Variables & Secrets
.env
.env.*

# Kubernetes secrets and local credentials
# Keep deployable manifests and sanitized *.example templates trackable.
**/secret.yaml
**/secrets.yaml
**/*-secret.yaml
**/*-secrets.yaml
**/credentials.json
**/kubeconfig
**/kubeconfig.*
*.pem
*.key
*.p12
*.pfx
*.jks
!**/*.example
# Environment templates expose configuration names and stay local.
.env.example
# Secret templates also expose credential names and are kept out of Git.
**/secret.yaml.example
**/secrets.yaml.example
**/*-secret.yaml.example
**/*-secrets.yaml.example


# macOS system files
.DS_Store
.AppleDouble
.LSOverride

