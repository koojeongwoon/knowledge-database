# Database Type: sqlite, postgres
DB_TYPE=sqlite

# SQLite Connection Settings (DB_TYPE=sqlite일 때 활성화)
DB_NAME=knowledge.db

# PostgreSQL Connection Settings (DB_TYPE=postgres일 때 활성화)
# [프리셋 1] 로컬 PostgreSQL 연동
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=knowledge_db

# [프리셋 2] K8s PostgreSQL 연동 (외부에서 Port-Forward 한 경우)
# DB_HOST=localhost
# DB_PORT=54320
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=knowledge_db

# [프리셋 3] K8s PostgreSQL 연동 (앱이 K8s 클러스터 내부 Pod로 들어간 경우)
# DB_HOST=postgres-service.llm-wiki.svc.cluster.local
# DB_PORT=54320
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=knowledge_db

# Embedding Settings
# 공급자 종류: fake, openai, bge-m3
EMBEDDING_PROVIDER=fake

# OpenAI API Key (openai 공급자 선택 시 필수)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI 임베딩 차원 (bge-m3는 1024로 자동 고정되므로 무시됨)
EMBEDDING_DIM=1536

# 지식베이스(Obsidian Vault) 경로 설정 (기본값: . 즉 현재 디렉토리)
WIKI_DIR=.

# Unsplash Access Key (프로젝트 .env에서 소거되었으며, 글로벌 스킬 폴더 /Users/jw/.gemini/skills/blog_image_unsplash/.env 에서 격리 관리합니다)


# RAG & Retrieval Pipeline Settings (Optional)
# RRF_K=60
# SIMILARITY_THRESHOLD=0.35
# RERANKER_ENABLED=false
# RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1


